[
  {
    "context": "Workspace",
    "bindings": {}
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {}
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-/": [
        "editor::ToggleComments",
        {
          "advance_downwards": false
        }
      ]
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "cmd-ß": [
        "editor::ToggleComments",
        {
          "advance_downwards": false
        }
      ]
    }
  }
]
