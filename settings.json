{
  "minimap": {
    "show": "always"
  },
  "agent": {
    "button": false,
    "favorite_models": [],
    "model_parameters": []
  },
  "collaboration_panel": {
    "button": false
  },
  "status_bar": {
    "active_encoding_button": "enabled"
  },
  "colorize_brackets": false,
  "git": {
    "inline_blame": {
      "location": "status_bar",
      "enabled": true
    }
  },
  "indent_guides": {
    "coloring": "indent_aware"
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_user_menu": false,
    "show_user_picture": false,
    "show_sign_in": false
  },
  "project_panel": {
    "dock": "left"
  },
  "restore_on_startup": "launchpad",
  "terminal": {
    "shell": {
      "program": "dash"
    }
  },
  "buffer_font_family": "Fira Code",
  "autosave": {
    "after_delay": {
      "milliseconds": 500
    }
  },
  "disable_ai": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
    "anthropic_retention": false
  },
  "icon_theme": "Zed (Default)",
  "ui_font_size": 16,
  "buffer_font_size": 14.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  }
}
